:80 {
    encode gzip

    # Serve the Zola-built static site
    root * /var/www/garden
    file_server

    # Proxy Pocketbase API (for file access — images, PDFs, admin UI)
    handle /api/* {
        reverse_proxy localhost:8090
    }

    handle /_/* {
        reverse_proxy localhost:8090
    }

    # Pocketbase admin UI
    handle /admin* {
        reverse_proxy localhost:8090
    }
}
