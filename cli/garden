#!/usr/bin/env bash
# garden — publish a project folder to your garden site
# Usage:
#   garden login              authenticate and save credentials
#   garden publish [FOLDER]   upload folder contents (default: current dir)
#   garden whoami             show logged-in user
#   garden logout             clear saved credentials

set -euo pipefail

CONFIG_DIR="${HOME}/.config/garden"
CONFIG_FILE="${CONFIG_DIR}/config"
VERSION="1.0.0"

# ── Helpers ─────────────────────────────────────────────────────────────────

die()  { echo "error: $*" >&2; exit 1; }
info() { echo "→ $*"; }

load_config() {
    [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE" || true
    GARDEN_URL="${GARDEN_URL:-}"
    GARDEN_TOKEN="${GARDEN_TOKEN:-}"
}

require_auth() {
    load_config
    [[ -n "$GARDEN_URL" ]]   || die "Not logged in. Run: garden login"
    [[ -n "$GARDEN_TOKEN" ]] || die "Not logged in. Run: garden login"
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
GARDEN_URL="${GARDEN_URL}"
GARDEN_TOKEN="${GARDEN_TOKEN}"
GARDEN_USER="${GARDEN_USER:-}"
EOF
    chmod 600 "$CONFIG_FILE"
}

# Check dependencies
check_deps() {
    local missing=()
    command -v curl &>/dev/null || missing+=("curl")
    command -v jq   &>/dev/null || missing+=("jq")
    [[ ${#missing[@]} -eq 0 ]] || die "Missing required tools: ${missing[*]}"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_login() {
    check_deps

    echo "Garden Login"
    echo "────────────"

    read -rp "Site URL (e.g. https://garden.example.com): " url
    url="${url%/}"   # strip trailing slash

    read -rp "Email: " email
    read -rsp "Password: " password
    echo

    response=$(curl -sf -X POST "${url}/api/collections/users/auth-with-password" \
        -H "Content-Type: application/json" \
        -d "{\"identity\":\"${email}\",\"password\":\"${password}\"}" \
        2>/dev/null) || die "Login failed — check URL and credentials"

    token=$(echo "$response" | jq -r '.token // empty')
    username=$(echo "$response" | jq -r '.record.name // .record.username // .record.email // "unknown"')

    [[ -n "$token" ]] || die "Login failed — no token returned"

    GARDEN_URL="$url"
    GARDEN_TOKEN="$token"
    GARDEN_USER="$username"
    save_config

    echo "Logged in as: $username"
    echo "Config saved: $CONFIG_FILE"
}

cmd_whoami() {
    load_config
    if [[ -z "$GARDEN_URL" || -z "$GARDEN_TOKEN" ]]; then
        echo "Not logged in. Run: garden login"
    else
        echo "User:   ${GARDEN_USER:-unknown}"
        echo "Server: $GARDEN_URL"
    fi
}

cmd_logout() {
    [[ -f "$CONFIG_FILE" ]] && rm "$CONFIG_FILE" && echo "Logged out." || echo "Not logged in."
}

cmd_publish() {
    check_deps
    require_auth

    local folder="${1:-.}"
    folder="${folder%/}"   # strip trailing slash
    [[ -d "$folder" ]] || die "Not a directory: $folder"

    # ── Find the main markdown file ────────────────────────────────────────
    local md_file
    # prefer index.md, README.md, or the only .md file
    if [[ -f "$folder/index.md" ]]; then
        md_file="$folder/index.md"
    elif [[ -f "$folder/README.md" ]]; then
        md_file="$folder/README.md"
    else
        md_file=$(find "$folder" -maxdepth 1 -name "*.md" | head -1)
    fi
    [[ -n "$md_file" ]] || die "No markdown file found in $folder"

    # ── Extract metadata from front matter or headings ────────────────────
    local title slug description contributor tags

    # Title: from front matter "title = ..." or first "# Heading"
    title=$(grep -m1 -E '^title\s*=' "$md_file" \
            | sed 's/title[[:space:]]*=[[:space:]]*//' | tr -d '"' || true)
    if [[ -z "$title" ]]; then
        title=$(grep -m1 '^# ' "$md_file" | sed 's/^# //' || true)
    fi
    if [[ -z "$title" ]]; then
        title=$(basename "$folder")
    fi

    # Description: from front matter
    description=$(grep -m1 -E '^description\s*=' "$md_file" \
                  | sed 's/description[[:space:]]*=[[:space:]]*//' | tr -d '"' || true)

    # Tags: from front matter (comma-separated)
    tags=$(grep -m1 -E '^tags\s*=' "$md_file" \
           | sed 's/tags[[:space:]]*=[[:space:]]*//' | tr -d '[]"' || true)

    # Slug: sanitise folder name
    slug=$(basename "$folder" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')

    # Contributor: logged-in username
    contributor="${GARDEN_USER:-unknown}"

    # ── Check for existing project with this slug ─────────────────────────
    existing=$(curl -sf \
        "${GARDEN_URL}/api/collections/projects/records?filter=(slug='${slug}')" \
        -H "Authorization: ${GARDEN_TOKEN}" | jq -r '.items[0].id // empty')

    # ── Build the curl multipart request ──────────────────────────────────
    local curl_args=()
    local method="POST"
    local endpoint="${GARDEN_URL}/api/collections/projects/records"

    if [[ -n "$existing" ]]; then
        method="PATCH"
        endpoint="${GARDEN_URL}/api/collections/projects/records/${existing}"
        info "Updating existing project: $title (id: $existing)"
    else
        info "Publishing new project: $title"
    fi

    curl_args+=(
        -sf -X "$method" "$endpoint"
        -H "Authorization: ${GARDEN_TOKEN}"
        -F "title=${title}"
        -F "slug=${slug}"
        -F "contributor=${contributor}"
        -F "content=<${md_file}"
    )

    [[ -n "$description" ]] && curl_args+=(-F "description=${description}")
    [[ -n "$tags" ]]        && curl_args+=(-F "tags=[${tags}]")

    # Attach images
    local img_count=0
    for img in "$folder"/*.{jpg,jpeg,png,gif,webp,JPG,JPEG,PNG,GIF,WEBP} 2>/dev/null; do
        [[ -f "$img" ]] || continue
        curl_args+=(-F "images=@${img}")
        img_count=$((img_count + 1))
    done

    # Attach PDFs
    local pdf_count=0
    for pdf in "$folder"/*.{pdf,PDF} 2>/dev/null; do
        [[ -f "$pdf" ]] || continue
        curl_args+=(-F "attachments=@${pdf}")
        pdf_count=$((pdf_count + 1))
    done

    # ── Upload ─────────────────────────────────────────────────────────────
    info "Uploading: 1 markdown, ${img_count} image(s), ${pdf_count} PDF(s)..."

    response=$(curl "${curl_args[@]}" 2>/dev/null) || die "Upload failed — check connection and token"

    local record_id
    record_id=$(echo "$response" | jq -r '.id // empty')
    [[ -n "$record_id" ]] || {
        echo "$response" | jq . 2>/dev/null || echo "$response"
        die "Upload failed — see response above"
    }

    echo ""
    echo "Published: ${title}"
    echo "URL:       ${GARDEN_URL}/projects/${slug}/"
    echo ""
    echo "The site will rebuild in a moment."
}

cmd_help() {
    cat <<EOF
garden v${VERSION} — publish projects to your garden site

Commands:
  login               authenticate with your garden server
  publish [FOLDER]    upload folder contents (default: current directory)
  whoami              show current logged-in user
  logout              clear saved credentials
  help                show this message

Folder structure:
  my-project/
  ├── index.md        main content (required)
  ├── image.png       images (optional, any of: jpg png gif webp)
  └── report.pdf      PDFs (optional)

Front matter (optional, in index.md):
  +++
  title = "My Project"
  description = "A short description"
  tags = ["hardware", "iot"]
  +++

Config: ${CONFIG_FILE}
EOF
}

# ── Entry point ──────────────────────────────────────────────────────────────

case "${1:-help}" in
    login)   cmd_login ;;
    publish) cmd_publish "${2:-}" ;;
    whoami)  cmd_whoami ;;
    logout)  cmd_logout ;;
    help|-h|--help) cmd_help ;;
    *) die "Unknown command: ${1}. Run: garden help" ;;
esac
